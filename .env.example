
# APPLICATION
APP_NAME=OmniSupport
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# FRONTEND
FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# DATABASE
DATABASE_URL=postgresql://omnisupport:omnisupport_secret@localhost:5432/omnisupport_db?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_minimum_32_chars_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_chars_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# OPENAI
OPENAI_API_KEY=sk-your_openai_api_key
AI_PROVIDER=openai
AI_ESCALATION_THRESHOLD=75
AI_RISK_HIGH_THRESHOLD=70
AI_RISK_CRITICAL_THRESHOLD=85

# EMAIL
EMAIL_PROVIDER=smtp
EMAIL_FROM=support@yourdomain.com

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# AWS SES (alternative)
# EMAIL_PROVIDER=ses
# AWS_SES_REGION=us-east-1

# WHATSAPP
WHATSAPP_PROVIDER=twilio
WHATSAPP_ACCOUNT_SID=your_twilio_account_sid
WHATSAPP_AUTH_TOKEN=your_twilio_auth_token
WHATSAPP_FROM_NUMBER=+14155238886
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# STORAGE
STORAGE_PROVIDER=local

# Local storage
LOCAL_STORAGE_PATH=./uploads
LOCAL_STORAGE_URL=http://localhost:3000/uploads
LOCAL_STORAGE_SECRET=local_storage_signing_secret

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=omnisupport-attachments
# AWS_ENDPOINT=http://localhost:4566  # LocalStack for dev

MAX_UPLOAD_SIZE=10485760

# RATE LIMITING
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# LOGGING
LOG_LEVEL=debug

# WEBSOCKET
WEBSOCKET_ENABLED=true

# PLATFORM ADMIN (seed only)
PLATFORM_ADMIN_EMAIL=admin@omnisupport.io
PLATFORM_ADMIN_PASSWORD=Admin@123456!