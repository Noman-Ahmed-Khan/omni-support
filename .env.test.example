NODE_ENV=test
PORT=3001
APP_NAME=OmniSupport-Test

DATABASE_URL=postgresql://omnisupport:omnisupport_secret@localhost:5432/omnisupport_test?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
SKIP_REDIS=true

JWT_ACCESS_SECRET=test_access_secret_minimum_32_characters_long
JWT_REFRESH_SECRET=test_refresh_secret_minimum_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

EMAIL_PROVIDER=smtp
EMAIL_FROM=test@omnisupport.io
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASSWORD=test

OPENAI_API_KEY=sk-test-key
AI_PROVIDER=openai

STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads-test
LOCAL_STORAGE_SECRET=test_storage_secret

WHATSAPP_PROVIDER=twilio
WHATSAPP_ACCOUNT_SID=test_sid
WHATSAPP_AUTH_TOKEN=test_token
WHATSAPP_FROM_NUMBER=+14155238886
WHATSAPP_WEBHOOK_SECRET=test_webhook_secret
SKIP_TWILIO=true

FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001

LOG_LEVEL=error
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=1000